telegram_bot_token: "YOUR_BOT_TOKEN_HERE"
claude_code_project_path: "/path/to/your/codebase"
poll_interval_seconds: 5
task_timeout_minutes: 30

# Usernames (without @) allowed to execute tasks. Empty list = allow anyone.
# Get username from Telegram profile settings.
allowed_telegram_usernames: []

# Kaizen scanner settings
kaizen:
  scan_interval_hours: 6
  categories:
    reliability:
      max_results: 2
      signals:
        - high_failure_rate
        - task_timeout
        - queue_stall
    performance:
      max_results: 2
      signals:
        - queue_backlog
        - slow_tasks
    maintainability:
      max_results: 2
      signals:
        - code_complexity
        - large_file
    code_quality:
      max_results: 2
      signals:
        - missing_tests
        - missing_types
    feature_requests:
      max_results: 2
      signals:
        - requested_feature
        - repeated_pattern
